# наводиться на окно по наведению курсора автоматически
yabai -m config focus_follows_mouse autofocus

# center mouse on window with focus
yabai -m config mouse_follows_focus on

# делить окнa на двое по дефолту
yabai -m config layout bsp
yabai -m config window_placement first_child

yabai -m config --space 4 layout stack

# не позиционировать приложения автоматически
yabai -m rule --add app="^System Settings$" manage=off grid=4:4:1:0:2:4
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^Finder$" manage=off grid=12:12:1:1:10:10
yabai -m rule --add app="^Preview$" manage=off grid=4:4:1:1:2:2
yabai -m rule --add app="^Font Book$" manage=off grid=4:4:1:1:2:2
yabai -m rule --add app="^VLC$" manage=off grid=4:4:1:1:2:2

# padding set to 12px
yabai -m config top_padding 12
yabai -m config bottom_padding 12
yabai -m config left_padding 12
yabai -m config right_padding 12
yabai -m config window_gap 12

# spaces for apps
yabai -m rule --add app="^Firefox$" space=1
yabai -m rule --add app="^kitty$" space=2
yabai -m rule --add app="^DBeaver$" space=3
yabai -m rule --add app="^VLC$" space=3

yabai -m rule --add app="^Spotify$" space=4
yabai -m rule --add app="^Telegram$" space=4
yabai -m rule --add app="^Discord$" space=4
yabai -m rule --add app="^GIMP$" space=4


